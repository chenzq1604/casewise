# ============================================
# CaseWise 法律AI工具 - 环境变量配置模板
# 使用说明：复制此文件为 .env 并填入实际值
# ============================================

# ---------- 火山方舟 API 配置 ----------
# 火山方舟 API Key（必填，从火山方舟控制台获取）
ARK_API_KEY=your_ark_api_key_here

# 火山方舟 API 地址
ARK_API_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# 对话模型名称
ARK_CHAT_MODEL=ark-code-latest

# Embedding 模型名称
ARK_EMBEDDING_MODEL=doubao-embedding-vision

# ---------- 数据库配置 ----------
# SQLite 数据库文件路径
DB_PATH=./data/casewise.db

# ChromaDB 持久化存储目录
CHROMA_PERSIST_DIR=./data/chroma_db

# ---------- 文件存储配置 ----------
# 用户上传文件目录
UPLOAD_DIR=./uploads

# ---------- 应用配置 ----------
# 运行环境：development / production
ENV=development

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 服务监听端口
PORT=6800

# ---------- 安全配置 ----------
# JWT 密钥（生产环境必填，不设置则每次启动自动生成随机密钥）
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# ---------- 服务器部署配置（仅部署时使用） ----------
CASEWISE_SERVER_HOST=your-server-ip
CASEWISE_SERVER_PORT=22
CASEWISE_SERVER_USER=your-username
CASEWISE_SERVER_PASS=your-password
